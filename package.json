{
	"name": "@oliyy_/satisfactory-asset-tool",
	"version": "0.1.1",
	"description": "Node-first tooling for generating Satisfactory asset-pack source files and importing them into Unreal.",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@11.1.1",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/oliyy/satisfactory-asset-tool.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist/src",
		"unreal/scripts/*.py",
		"unreal/asset_tool/*.py",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js",
			"default": "./dist/src/index.js"
		}
	},
	"types": "./dist/src/index.d.ts",
	"main": "./dist/src/index.js",
	"bin": {
		"sat": "./dist/src/cli/index.js"
	},
	"scripts": {
		"build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
		"check": "pnpm typecheck && pnpm format:check && pnpm lint && pnpm build",
		"format": "prettier . --write --cache",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"prepack": "pnpm build",
		"publish:npm": "pnpm release:check && pnpm publish --access public --registry https://registry.npmjs.org/ --config.@oliyy_:registry=https://registry.npmjs.org/ --no-git-checks",
		"release:check": "pnpm check && pnpm test && pnpm pack --dry-run",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "pnpm build && node --test dist/test/**/*.test.js",
		"sat": "pnpm build && node ./dist/src/cli/index.js",
		"version:major": "pnpm version major",
		"version:minor": "pnpm version minor",
		"version:patch": "pnpm version patch"
	},
	"engines": {
		"node": ">=24"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.10.0",
		"eslint": "^10.5.0",
		"eslint-plugin-functional": "^10.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"stylelint": "^17.13.0",
		"stylelint-prettier": "^5.0.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.61.0"
	}
}
